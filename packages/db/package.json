{
  "name": "@crm-bot/db",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prisma:generate": "pnpm exec prisma generate --schema prisma/schema.prisma",
    "prisma:push": "pnpm exec prisma db push --schema prisma/schema.prisma --skip-generate",
    "prisma:migrate": "pnpm exec prisma migrate deploy --schema prisma/schema.prisma",
    "build": "tsc -p tsconfig.json",
    "init": "tsx src/init.ts",
    "import:json": "tsx src/import-json-to-postgres.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^6.16.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
